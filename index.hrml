<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <title>لوحة الشرف الفلكية</title>
    <script src="https://www.gstatic.com/firebasejs/10.8.1/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/10.8.1/firebase-database-compat.js"></script>
    <style>
        body { font-family: 'Segoe UI', sans-serif; background: #050510; color: white; margin: 0; padding: 20px; overflow: hidden; }
        h1 { color: #00d2ff; text-align: center; margin-bottom: 5px; font-size: 2.5em; text-transform: uppercase; }
        
        #leaderboard-container { 
            position: relative; max-width: 900px; margin: auto; 
            background: rgba(255, 255, 255, 0.03); 
            border-radius: 15px; padding: 10px; height: 85vh;
        }

        .player-row { 
            position: absolute; left: 10px; right: 10px; height: 40px; /* تقليل الارتفاع */
            display: flex; justify-content: space-between; align-items: center;
            background: #16213e; padding: 0 15px; border-radius: 5px; 
            font-size: 1.1em; transition: all 1s ease-in-out; box-sizing: border-box;
        }

        .rank-1 { background: #f9a826; color: black; font-weight: bold; transform: scale(1.02); z-index: 10; }
        .rank-2 { background: #e0e0e0; color: black; z-index: 9; }
        .rank-3 { background: #cd7f32; color: white; z-index: 8; }
        
        /* تأثير النجوم في الخلفية */
        .stars { position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: -1; background: url('https://www.transparenttextures.com/patterns/stardust.png'); opacity: 0.3; }
    </style>
</head>
<body>
    <div class="stars"></div>
    <h1>🔭 قائمة فرسان الفلك 🚀</h1>
    <p style="text-align:center; color: #aaa; margin-top:0;">مديرية الشباب والرياضة - سيدي بلعباس</p>

    <div id="leaderboard-container"></div>

    <script>
        const firebaseConfig = {
            apiKey: "AIzaSyCgZgpQHl1aJcbtIe8otscDfA_Plzl7n_c",
            authDomain: "test-b8f87.firebaseapp.com",
            databaseURL: "https://test-b8f87-default-rtdb.firebaseio.com",
            projectId: "test-b8f87",
            storageBucket: "test-b8f87.firebasestorage.app",
            messagingSenderId: "199270761575",
            appId: "1:199270761575:web:fdb307007a678a498680c2"
        };
        firebase.initializeApp(firebaseConfig);
        const db = firebase.database();

        db.ref('scores').on('value', (snap) => {
            const data = snap.val();
            const container = document.getElementById('leaderboard-container');
            if (!data) return;

            let scores = {};
            for (let k in data) {
                scores[data[k].name] = (scores[data[k].name] || 0) + data[k].score;
            }

            let sorted = Object.keys(scores).map(n => ({n: n, s: scores[n]})).sort((a,b) => b.s - a.s);

            sorted.forEach((p, i) => {
                let id = 'p-' + p.n.replace(/\s+/g, '-');
                let row = document.getElementById(id);
                if (!row) {
                    row = document.createElement('div');
                    row.id = id;
                    row.className = 'player-row';
                    container.appendChild(row);
                }
                row.style.top = (i * 45 + 10) + 'px'; // 45px مسافة بين كل سطر
                row.innerHTML = `<span>#${i+1} - ${p.n}</span><span>${p.s} نقطة</span>`;
                
                row.classList.remove('rank-1', 'rank-2', 'rank-3');
                if(i==0) row.classList.add('rank-1');
                else if(i==1) row.classList.add('rank-2');
                else if(i==2) row.classList.add('rank-3');
            });
        });
    </script>
</body>
</html>
